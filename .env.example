# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_ADMIN_IDS=123456789,987654321

# Optional: groups for Telegram notifications only (not used for access control).
# Format: comma-separated group IDs, optionally with topic ID after colon.
# Example: TELEGRAM_GROUP_IDS=-1001234567890,-1009876543210:42
# TELEGRAM_GROUP_IDS=-1001234567890

# Database Configuration
DB_PASSWORD=secure_password_here
DATABASE_URL=postgresql+asyncpg://filmbot:${DB_PASSWORD}@127.0.0.1:5432/filmbot

# WebApp / nginx
DOMAIN=yourdomain.com
WEBAPP_URL=https://${DOMAIN}
CERTBOT_EMAIL=admin@yourdomain.com

# Bot t.me URL for the inline button in group chats.
# Use https://t.me/your_bot_username to open the private chat (basic).
# After registering a Mini App in BotFather (/newapp), use:
# https://t.me/your_bot_username/app_name  — opens the WebApp directly.
BOT_URL=https://t.me/your_bot_username
